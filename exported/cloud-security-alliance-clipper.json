{
	"schemaVersion": "0.1.0",
	"name": "cloud-security-alliance",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "author",
			"value": "CSA",
			"type": "multitext"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{prompt:\\\"a summary of the page\\\"}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "clippings csa",
			"type": "multitext"
		}
	],
	"triggers": [
		"https://circle.cloudsecurityalliance.org/"
	],
	"noteNameFormat": "{{title}}",
	"path": "cloud-security-alliance/"
}